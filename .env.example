# Discord bot token for the bot application you want to run
MM_TOKEN=

# For a single-server setup, both IDs should be the same
MM_MAIN_SERVER_ID=
MM_INBOX_SERVER_ID=

# Channel where closed-thread logs are posted
MM_LOG_CHANNEL_ID=

# Category where new modmail thread channels are created
MM_NEW_THREAD_CATEGORY_ID=

# One or more role IDs, user IDs, or permission names separated by ||
# Example: MM_INBOX_SERVER_PERMISSION=123||456||manageMessages
MM_INBOX_SERVER_PERMISSION=

# Recommended production defaults
MM_ATTACHMENT_STORAGE=discord
MM_ATTACHMENT_STORAGE_CHANNEL_ID=
MM_RESPONSE_MESSAGE="Thank you for reaching out. Our team will reply here as soon as possible."
MM_CLOSE_MESSAGE="This conversation is now closed. If you need anything else, send a new message anytime."
MM_STATUS="DM me for help"
MM_HOST=127.0.0.1
MM_PORT=8891
MM_IGNORE_ACCIDENTAL_THREADS=on
MM_ALLOW_USER_CLOSE=on
MM_FALLBACK_ROLE_NAME=
